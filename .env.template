# web-search-plus-plugin — configure at least one provider below
# You do not need every key. Good starter setup: Tavily + Linkup + Brave.

# Serper (Google Search) — https://serper.dev
SERPER_API_KEY=

# Brave Search — https://api.search.brave.com
BRAVE_API_KEY=
# Optional Brave defaults
BRAVE_COUNTRY=
BRAVE_SEARCH_LANG=
BRAVE_SAFESEARCH=

# Tavily (research search + extraction) — https://tavily.com
TAVILY_API_KEY=

# Linkup (source-grounded search + preferred extraction) — https://linkup.so
LINKUP_API_KEY=

# Exa (semantic/deep search + extraction) — https://exa.ai
EXA_API_KEY=

# Querit (multilingual AI search) — https://querit.ai
QUERIT_API_KEY=

# Firecrawl (search + extraction) — https://firecrawl.dev
FIRECRAWL_API_KEY=

# Perplexity (answer-style search) — https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=

# Kilo.ai gateway (Perplexity-compatible answer route) — https://api.kilo.ai
KILOCODE_API_KEY=

# You.com (search + extraction) — https://api.you.com
YOU_API_KEY=

# SearXNG (self-hosted, no API key needed)
SEARXNG_INSTANCE_URL=

# Optional beta: enable web_answer_plus
WSP_ENABLE_WEB_ANSWER=

# Optional danger flag: allow private-network SearXNG
# SEARXNG_ALLOW_PRIVATE=true

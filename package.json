{
  "name": "web-search-plus-plugin",
  "version": "2.0.1",
  "description": "OpenClaw plugin: multi-provider web search (Serper/Google, Tavily, Querit/Multilingual AI Search, Exa/Neural+Deep, Perplexity, You.com, SearXNG) with intelligent auto-routing",
  "type": "module",
  "main": "index.ts",
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "compat": {
      "pluginApi": ">=2026.3.22"
    },
    "env": {
      "SERPER_API_KEY": "optional — Google/Serper search",
      "TAVILY_API_KEY": "optional — Tavily research search",
      "EXA_API_KEY": "optional — Exa neural search",
      "QUERIT_API_KEY": "optional — Querit multilingual search",
      "PERPLEXITY_API_KEY": "optional — Perplexity AI search",
      "YOUCOM_API_KEY": "optional — You.com search",
      "SEARXNG_URL": "optional — SearXNG self-hosted instance URL",
      "SEARXNG_ALLOW_PRIVATE": "optional — set true to allow private IPs for SearXNG (disables SSRF protection)"
    }
  },
  "files": [
    "index.ts",
    "openclaw.plugin.json",
    ".env.template",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "openclaw",
    "plugin",
    "search",
    "serper",
    "tavily",
    "querit",
    "exa",
    "exa-deep",
    "perplexity",
    "you",
    "searxng",
    "web-search",
    "auto-routing"
  ],
  "peerDependencies": {
    "openclaw": ">=2026.3.22"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/robbyczgw-cla/web-search-plus-plugin"
  },
  "author": "robbyczgw-cla",
  "license": "MIT"
}

{
  "name": "web-search-plus-plugin-v2",
  "version": "2.5.2",
  "description": "OpenClaw plugin: one clean set of web tools for multi-provider search, extraction, and optional beta answer synthesis across Serper/Google, Brave, Tavily, Exa, Querit, Linkup, Firecrawl, Perplexity, Kilo gateway, You.com, and SearXNG.",
  "type": "module",
  "main": "index.ts",
  "scripts": {
    "test": "node --test test/*.test.ts",
    "build": "esbuild index.ts --bundle --platform=node --format=esm --target=node22 --outfile=dist/index.js"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "compat": {
      "pluginApi": ">=2026.3.22",
      "minGatewayVersion": "2026.4.23"
    },
    "build": {
      "openclawVersion": "2026.4.23",
      "pluginSdkVersion": "2026.4.23"
    },
    "runtimeExtensions": [
      "./dist/index.js"
    ]
  },
  "files": [
    "index.ts",
    "extract.ts",
    "routing-config.ts",
    "runtime-config.ts",
    "openclaw.plugin.json",
    "dist/index.js"
  ],
  "keywords": [
    "openclaw",
    "plugin",
    "search",
    "serper",
    "brave",
    "tavily",
    "linkup",
    "querit",
    "exa",
    "exa-deep",
    "firecrawl",
    "perplexity",
    "you",
    "searxng",
    "web-search",
    "auto-routing"
  ],
  "peerDependencies": {
    "openclaw": ">=2026.3.22"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/robbyczgw-cla/web-search-plus-plugin"
  },
  "author": "robbyczgw-cla",
  "license": "MIT",
  "devDependencies": {
    "esbuild": "^0.25.0"
  }
}
